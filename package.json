{
  "name": "git-hygiene-workspace",
  "private": true,
  "description": "The ultimate zero-dependency metadata validator for modern Git workflows. Enforce conventional commits, branch naming patterns, and PR titles with blazing-fast native Node.js performance.",
  "author": {
    "name": "Chitrank Agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://www.chitrankagnihotri.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitranklabs/git-hygiene"
  },
  "bugs": {
    "url": "https://github.com/chitranklabs/git-hygiene/issues"
  },
  "homepage": "https://github.com/chitranklabs/git-hygiene",
  "keywords": [
    "git",
    "conventional-commits",
    "branch-naming",
    "github-actions",
    "lint",
    "hygiene",
    "developer-experience",
    "dx",
    "commitlint",
    "metadata",
    "automation",
    "jsr",
    "npm",
    "zero-dependency",
    "typescript",
    "native-ts"
  ],
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "dev": "turbo dev",
    "deps:update": "pnpm update --interactive --latest -r",
    "changelog": "git-cliff -o CHANGELOG.md",
    "release": "pnpm build && pnpm changelog && echo 'Ready to publish!'"
  },
  "devDependencies": {
    "git-cliff": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.0.2",
    "globals": "^17.5.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.26.0"
  },
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  }
}
