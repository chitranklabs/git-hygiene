{
  "name": "@chitrank2050/git-hygiene-core",
  "version": "0.4.7",
  "description": "Core validation engine for git-hygiene. Validates conventional commits, branch names, and PR titles.",
  "author": {
    "name": "Chitrank Agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://www.chitrankagnihotri.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitranklabs/git-hygiene"
  },
  "bugs": {
    "url": "https://github.com/chitranklabs/git-hygiene/issues"
  },
  "homepage": "https://github.com/chitranklabs/git-hygiene/tree/main/packages/core#readme",
  "keywords": [
    "git",
    "conventional-commits",
    "branch-naming",
    "lint",
    "hygiene",
    "commitlint",
    "metadata",
    "core"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --minify",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "test:cov": "mkdir -p coverage && node --experimental-strip-types --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info tests/**/*.test.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts"
  },
  "dependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/lint": "^20.5.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "conventional-changelog-preset-loader": "^5.0.0",
    "conventional-recommended-bump": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "git-hygiene": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "types": [
      "feat",
      "fix",
      "chore",
      "docs",
      "style",
      "refactor",
      "perf",
      "test",
      "build",
      "ci",
      "revert",
      "maintenance",
      "renovate"
    ]
  }
}
