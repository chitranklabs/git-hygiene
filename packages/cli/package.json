{
  "name": "@chitrank2050/git-hygiene",
  "version": "0.3.0",
  "description": "The ultimate zero-dependency metadata validator for modern Git workflows. CLI tool.",
  "author": {
    "name": "Chitrank Agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://www.chitrankagnihotri.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitranklabs/git-hygiene"
  },
  "bugs": {
    "url": "https://github.com/chitranklabs/git-hygiene/issues"
  },
  "homepage": "https://github.com/chitranklabs/git-hygiene/tree/main/packages/cli#readme",
  "keywords": [
    "git",
    "conventional-commits",
    "branch-naming",
    "lint",
    "hygiene",
    "commitlint",
    "metadata",
    "cli"
  ],
  "type": "module",
  "bin": {
    "git-hygiene": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean --minify",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "test:cov": "mkdir -p coverage && node --experimental-strip-types --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info tests/**/*.test.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts"
  },
  "dependencies": {
    "@chitrank2050/git-hygiene-core": "workspace:*",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
